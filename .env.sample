# Цены за подписку (в рублях)
PRICE_1=150
PRICE_3=400
PRICE_6=750
PRICE_12=1320

# Цены в Telegram Stars
STARS_PRICE_1=99
STARS_PRICE_3=280
STARS_PRICE_6=525
STARS_PRICE_12=925

# Токен Telegram бота
TELEGRAM_TOKEN=token
# Прокси для Telegram Bot API (http/https). Пример: http://user:pass@ip:3128
TELEGRAM_PROXY_URL=

# Реферальная система
# REFERRAL_MODE=default | progressive
REFERRAL_MODE=default
# Количество дней реферального бонуса в режиме default
REFERRAL_DAYS=14
# Режим progressive: бонусы за первую и повторные оплаты
# Сколько дней получает пригласивший при первом пополнении реферала
REFERRAL_FIRST_REFERRER_DAYS=7
# Сколько дней получает новый пользователь при первом пополнении
REFERRAL_FIRST_REFEREE_DAYS=7
# Сколько дней получает пригласивший за каждое последующее пополнение реферала
REFERRAL_REPEAT_REFERRER_DAYS=3

# Учитывать дни триала при покупке платной подписки (true/false)
TRIAL_ADD_TO_PAID=true

# Язык по умолчанию для сообщений бота (en или ru)
DEFAULT_LANGUAGE=ru
# Символ валюты по умолчанию
DEFAULT_CURRENCY_SYMBOL=RUB

# URL Telegram Web App (если пустой, не используется)
MINI_APP_URL=

# Не изменяйте, если не знаете, что делаете
# Строка подключения к базе данных PostgreSQL
DATABASE_URL=postgres://postgres:postgres@db:5432/postgres?sslmode=disable

# Не изменяйте, если не знаете, что делаете
# Имя пользователя PostgreSQL
POSTGRES_USER=postgres
# Не изменяйте, если не знаете, что делаете
# Пароль PostgreSQL
POSTGRES_PASSWORD=postgres
# Не изменяйте, если не знаете, что делаете
# Имя базы данных PostgreSQL
POSTGRES_DB=postgres

# Порт для healthcheck endpoint
HEALTH_CHECK_PORT=3000

# URL API Remnawave
REMNAWAVE_URL=http://remnawave:3000
# Режим Remnawave (remote/local). Если local - можно передать http://remnawave:3000 в REMNAWAVE_URL
REMNAWAVE_MODE=local
# Токен аутентификации для Remnawave API
REMNAWAVE_TOKEN=token

# Включить/отключить способ оплаты CryptoPay (true/false)
CRYPTO_PAY_ENABLED=true
# Токен API CryptoPay
CRYPTO_PAY_TOKEN=token
# URL API CryptoPay
CRYPTO_PAY_URL=https://pay.crypt.bot

# Включить/отключить способ оплаты YooKassa (true/false)
YOOKASA_ENABLED=true
# Секретный ключ API YooKassa
YOOKASA_SECRET_KEY=key
# Идентификатор магазина YooKassa
YOOKASA_SHOP_ID=id
# URL API YooKassa
YOOKASA_URL=https://api.yookassa.ru/v3
# Email адрес, связанный с аккаунтом YooKassa
YOOKASA_EMAIL=exmaple@mail.com

MOYNALOG_ENABLED=false
MOYNALOG_USERNAME=
MOYNALOG_PASSWORD=
MOYNALOG_URL=https://lknpd.nalog.ru/api/v1
MOYNALOG_PROXY_URL=

# Максимально разрешенный трафик в гб (0 для неограниченного)
TRAFFIC_LIMIT=0

# Включить/отключить способ оплаты Telegram Stars (true/false)
TELEGRAM_STARS_ENABLED=true
# Требовать успешную оплату через криптовалюту или карту перед использованием Telegram Stars (true/false). По умолчанию: false
REQUIRE_PAID_PURCHASE_FOR_STARS=false

# Настройки пробных подписок
# Максимально разрешенный трафик в гб для пробных подписок
TRIAL_TRAFFIC_LIMIT=3
# Количество дней для пробных подписок (если 0 = отключено)
TRIAL_DAYS=14
# Стратегия сброса трафика для пробных подписок (day/week/month/never). По умолчанию: month
TRIAL_TRAFFIC_LIMIT_RESET_STRATEGY=day
# Список UUID squad, разделенных запятыми, для назначения пробным пользователям (опционально, если не установлено, используются SQUAD_UUIDS)
# Пример: TRIAL_INTERNAL_SQUADS=773db654-a8b2-413a-a50b-75c3536238fd,bc979bdd-f1fa-4d94-8a51-38a0f518a2a2
TRIAL_INTERNAL_SQUADS=
# Один внешний UUID squad для назначения пробным пользователям (опционально, если не установлено, используется EXTERNAL_SQUAD_UUID)
# Пример: TRIAL_EXTERNAL_SQUAD_UUID=773db654-a8b2-413a-a50b-75c3536238fd
TRIAL_EXTERNAL_SQUAD_UUID=
# Тег для назначения пробным пользователям в Remnawave (опционально, если не установлен, используется обычный REMNAWAVE_TAG)
# Формат: только заглавные буквы, цифры и подчеркивания (^[A-Z0-9_]+$)
# Пример: TRIAL_REMNAWAVE_TAG=TRIAL
TRIAL_REMNAWAVE_TAG=TRIAL_TAG

# ID Telegram админа
ADMIN_TELEGRAM_ID=123123123

# Заблокированные Telegram ID (разделенные запятыми)
# Пользователи с этими ID будут заблокированы и не смогут использовать бота
# Пример: BLOCKED_TELEGRAM_IDS=123456789,987654321
BLOCKED_TELEGRAM_IDS=

# Белый список Telegram ID (разделенные запятыми)
# Пользователи с этими ID будут обходить все проверки на подозрительных пользователей
# Пример: WHITELISTED_TELEGRAM_IDS=111111111,222222222,333333333
WHITELISTED_TELEGRAM_IDS=

# URL-адреса для кнопок в боте (опционально - если не установлены, кнопки не отображаются)
# URL страницы статуса сервера
SERVER_STATUS_URL="https://example.com/status"
# URL чата поддержки или страницы
SUPPORT_URL="https://example.com/support"
# URL страницы отзывов/обратной связи
FEEDBACK_URL="https://example.com/feedback"
# URL Telegram канала
CHANNEL_URL="https://t.me/examplechannel"
# URL инфы по серверам
SERVER_SELECTION_URL="https://t.me/examplechannel"
# URL юридические
PUBLIC_OFFER_URL="https://t.me/examplechannel"
PRIVACY_POLICY_URL="https://t.me/examplechannel"
USER_AGREEMENT_URL="https://t.me/examplechannel"
# URL видеоинструкции (если установлен, кнопка "📺 Видеоинструкция" отображается в разделе "Помощь")
VIDEO_GUIDE_URL="https://t.me/video"

# UUID отрядов для назначения пользователям (разделенные запятыми)
# Если указано, только squads с соответствующими UUID будут назначены новым пользователям
# Если пусто, будут назначены все доступные squads
# Пример: 773db654-a8b2-413a-a50b-75c3536238fd,bc979bdd-f1fa-4d94-8a51-38a0f518a2a2
SQUAD_UUIDS=

# Внешний UUID отряда для назначения пользователям (только один UUID)
# Используется при создании или обновлении пользователей на панели remnawave
# Пример: 773db654-a8b2-413a-a50b-75c3536238fd
EXTERNAL_SQUAD_UUID=

# Количество дней в месяце
DAYS_IN_MONTH=30

# Тег в Remnawave для обычных пользователей
# Формат: только заглавные буквы, цифры и подчеркивания (^[A-Z0-9_]+$)
# Пример: REMNAWAVE_TAG=TEST_TAG
REMNAWAVE_TAG=DEF_TAG

# Стратегия сброса трафика для обычных подписок (day/week/month/never). По умолчанию: month
TRAFFIC_LIMIT_RESET_STRATEGY=month

