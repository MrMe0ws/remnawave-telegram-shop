# =============================================================================
# Общее
# =============================================================================
# Не загружать .env из файла (например, в CI) — true / не задано
# DISABLE_ENV_FILE=true

# =============================================================================
# Telegram
# =============================================================================
TELEGRAM_TOKEN=token
# Прокси для Telegram Bot API (http/https). Пример: http://user:pass@ip:3128
TELEGRAM_PROXY_URL=

# Публичная ссылка на Web App в кнопках подключения (true/false). URL задаётся в MINI_APP_URL
IS_WEB_APP_LINK=false
# URL Telegram Mini App (если пусто — не используется)
MINI_APP_URL=

# =============================================================================
# Режим продаж и цены (classic)
# =============================================================================
# classic — цены из переменных PRICE_* / STARS_PRICE_*
# tariffs — цены и лимиты из таблиц tariff / tariff_price (миграция 000008), PRICE_* остаются обязательными для валидации конфига
SALES_MODE=tariffs

# Цены подписки (руб.), обязательны даже при SALES_MODE=tariffs
PRICE_1=150
PRICE_3=400
PRICE_6=750
PRICE_12=1320

# На кнопках периодов 3 / 6 / 12 мес добавлять экономию в %: сравнение с «N × цена за 1 мес»
# (classic — PRICE_1; tariffs — amount_rub за 1 мес этого тарифа). true/false, по умолчанию false
SHOW_LONG_TERM_SAVINGS_PERCENT=true

# Цены в Telegram Stars (если TELEGRAM_STARS_ENABLED=true; по умолчанию берутся из PRICE_*)
STARS_PRICE_1=99
STARS_PRICE_3=280
STARS_PRICE_6=525
STARS_PRICE_12=925

# ₽ за 1 Telegram Star: админка/расчёт Stars; при LOYALTY_ENABLED — XP за оплату Stars ≈ звёзды × этот курс
RUB_PER_STAR=1.5

# =============================================================================
# База данных
# =============================================================================
DATABASE_URL=postgres://postgres:postgres@db:5432/postgres?sslmode=disable

# Для docker-compose (если используете)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# =============================================================================
# Сервис
# =============================================================================
# Порт HTTP healthcheck (по умолчанию в коде 8080)
HEALTH_CHECK_PORT=3002

# Язык по умолчанию для сообщений бота (например ru, en)
DEFAULT_LANGUAGE=ru

# =============================================================================
# Remnawave
# =============================================================================
REMNAWAVE_URL=http://remnawave:3000
# remote | local (local — подставляются X-Forwarded-* для локального API)
REMNAWAVE_MODE=local
REMNAWAVE_TOKEN=token
# Доп. заголовки к API: пары Key:Value через точку с запятой
# REMNAWAVE_HEADERS=X-Custom: value;Other: value

# =============================================================================
# Оплата: CryptoPay
# =============================================================================
CRYPTO_PAY_ENABLED=true
CRYPTO_PAY_URL=https://pay.crypt.bot
CRYPTO_PAY_TOKEN=token

# =============================================================================
# Оплата: YooKassa
# =============================================================================
YOOKASA_ENABLED=true
YOOKASA_URL=https://api.yookassa.ru/v3
YOOKASA_SHOP_ID=id
YOOKASA_SECRET_KEY=key
YOOKASA_EMAIL=example@mail.com

# =============================================================================
# Оплата: Telegram Stars
# =============================================================================
TELEGRAM_STARS_ENABLED=true
# Требовать успешную оплату картой/криптой до оплаты Stars (true/false)
REQUIRE_PAID_PURCHASE_FOR_STARS=false

# =============================================================================
# Tribute (если задан TRIBUTE_WEBHOOK_URL — остальные обязательны)
# =============================================================================
TRIBUTE_WEBHOOK_URL=
TRIBUTE_API_KEY=
TRIBUTE_PAYMENT_URL=

# =============================================================================
# МойНалог (чеки для YooKassa)
# =============================================================================
MOYNALOG_ENABLED=false
# По умолчанию в коде: https://lknpd.nalog.ru/api/v1 
MOYNALOG_URL=https://lknpd.nalog.ru/api/v1 
MOYNALOG_USERNAME=
MOYNALOG_PASSWORD=
MOYNALOG_PROXY_URL=

# =============================================================================
# Трафик и лимиты
# =============================================================================
# Лимит трафика в ГБ (0 = по смыслу конфигурации Remnawave/панели)
TRAFFIC_LIMIT=0
# Стратегия сброса трафика для платных подписок: day | week | month | month_rolling | never
# month — календарный месяц (1-е число); month_rolling — скользящий месяц от даты создания пользователя в панели (Remnawave MONTH_ROLLING)
TRAFFIC_LIMIT_RESET_STRATEGY=month

# =============================================================================
# Пробный период
# =============================================================================
TRIAL_DAYS=14
TRIAL_TRAFFIC_LIMIT=3
# day | week | month | month_rolling | never (если пусто в коде — month)
TRIAL_TRAFFIC_LIMIT_RESET_STRATEGY=month
# Учитывать дни триала при первой оплате (true/false)
TRIAL_ADD_TO_PAID=false


# =============================================================================
# ТЭГИ В remnawave 
# =============================================================================
# Тег пользователей в Remnawave (формат: ^[A-Z0-9_]+$)
REMNAWAVE_TAG=TG_TAG
# Тег для trial (формат ^[A-Z0-9_]+$); пусто — как REMNAWAVE_TAG
TRIAL_REMNAWAVE_TAG=TRIAL_TAG


# =============================================================================
# HWID / доп. устройства
# =============================================================================
# Продажа доп. HWID-слотов: кнопки «добавить устройство», продление extra вместе с подпиской, отдельная оплата HWID. true = как раньше; false = выкл (уже выданные слоты не трогаются). По умолчанию в коде true, если переменная не задана.
HWID_EXTRA_DEVICES_ENABLED=true
HWID_ADD_PRICE=75
HWID_ADD_STARS_PRICE=50
HWID_MAX_DEVICE=10
TRIAL_HWID_LIMIT=1
# 0 = использовать HWID_FALLBACK_DEVICE_LIMIT как базу для классического режима
PAID_HWID_LIMIT=0
HWID_FALLBACK_DEVICE_LIMIT=2

# =============================================================================
# Реферальная система
# =============================================================================
# default | progressive
REFERRAL_MODE=progressive
REFERRAL_DAYS=14
REFERRAL_FIRST_REFERRER_DAYS=7
REFERRAL_FIRST_REFEREE_DAYS=7
REFERRAL_REPEAT_REFERRER_DAYS=3

# =============================================================================
# Лояльность. 1руб = 1xp лояльности
# =============================================================================
# false — UI и начисления отключены, loyalty_xp в БД не трогаем
LOYALTY_ENABLED=false
# Потолок суммарной скидки: лояльность % + промо % (1–100, по умолчанию 100)
LOYALTY_MAX_TOTAL_DISCOUNT_PERCENT=50
# Минимум XP за успешную оплату, если сумма в ₽/Stars не дала баллов (0 = выкл.). Для Stars задайте RUB_PER_STAR — XP = звёзды × курс.
LOYALTY_XP_MIN_PER_PURCHASE=0

# =============================================================================
# Squads Remnawave (UUID через запятую)
# =============================================================================
# Пусто — подставляются все internal squads с панели
SQUAD_UUIDS=
EXTERNAL_SQUAD_UUID=

TRIAL_INTERNAL_SQUADS=
TRIAL_EXTERNAL_SQUAD_UUID=

# =============================================================================
# Календарь подписки
# =============================================================================
DAYS_IN_MONTH=30

# =============================================================================
# Админ и доступ
# =============================================================================
ADMIN_TELEGRAM_ID=123123123
# Пересылать админу сообщения пользователей и неизвестные команды (true/false)
FORWARD_USER_MESSAGES_TO_ADMIN=true

BLOCKED_TELEGRAM_IDS=
WHITELISTED_TELEGRAM_IDS=

# =============================================================================
# Опциональные URL для кнопок (пусто — кнопка скрыта)
# =============================================================================
SERVER_STATUS_URL=https://example.com/status
SUPPORT_URL=https://example.com/support
FEEDBACK_URL=https://example.com/feedback
CHANNEL_URL=https://t.me/examplechannel
TOS_URL=
SERVER_SELECTION_URL=https://t.me/examplechannel
PUBLIC_OFFER_URL=https://t.me/examplechannel
PRIVACY_POLICY_URL=https://t.me/examplechannel
TERMS_OF_SERVICE_URL=https://t.me/examplechannel
VIDEO_GUIDE_URL=https://t.me/video



# =============================================================================
# Web-кабинет (подробнее в documentation/cabinet/SETUP-GUIDE-RU.md)
# =============================================================================
# Главный переключатель кабинета. Если false — бот работает как раньше, cabinet API не поднимается.
CABINET_ENABLED=false
# Включает блок self-delete в профиле (ставьте true только на dev для возможности удалять аккаунты на стр профиля кабинета)
# В продакшене рекомендуется оставить false
CABINET_PROFILE_DELETE_ENABLED=false

# Публичный URL кабинета (для return_url YooKassa, ссылок в письмах и т.п.)
CABINET_PUBLIC_URL=https://cabinet.example.com

# Название и логотип в шапке SPA и в футере страниц входа (по умолчанию Cabinet + иконка щита).
CABINET_BRAND_NAME=Мой VPN

# Картинка: полный URL (https://...), путь с ведущим / или относительный к CABINET_PUBLIC_URL (например brand/logo.png).
# CABINET_BRAND_LOGO_URL=https://example.com/logo.png

# Либо файл на диске процесса бота; отдаётся как GET .../cabinet/api/public/brand-logo (и как favicon во вкладке).
# Относительный путь ищется: рядом с бинарником, затем cwd, затем CABINET_BRAND_LOGO_FILE_BASE (если задан).
# В Docker при WORKDIR=/ положите файл рядом с бинарём или укажите CABINET_BRAND_LOGO_FILE_BASE=/app
CABINET_BRAND_LOGO_FILE=./vpn_cat.png

# CABINET_BRAND_LOGO_FILE_BASE=/app
# Если заданы и URL, и файл — используется CABINET_BRAND_LOGO_URL.

# PWA (установка web-приложения на мобильные устройства)
# Включает install-prompt на фронте и runtime manifest по адресу:
# /cabinet/api/public/pwa-manifest.webmanifest
CABINET_PWA_ENABLED=false
# CABINET_PWA_APP_NAME=MEOWS VPN
# CABINET_PWA_SHORT_NAME=MEOWS

# URL для Telegram WebApp: кнопки «Мой VPN» и «Подключить VPN» в боте при CABINET_ENABLED=true.
# Если пусто — собирается как CABINET_PUBLIC_URL + CABINET_MINI_APP_PATH (ниже).
# CABINET_MINI_APP_URL=https://cabinet.example.com/cabinet/
# Путь SPA относительно CABINET_PUBLIC_URL (по умолчанию /cabinet/ — см. internal/cabinet/http/router.go).
# CABINET_MINI_APP_PATH=/cabinet/

# Разрешённые origin'ы для CORS, через запятую. Обычно совпадает с CABINET_PUBLIC_URL.
CABINET_ALLOWED_ORIGINS=https://cabinet.example.com

# Секрет для подписи access-JWT кабинета. >= 32 байт. Сгенерировать: openssl rand -hex 32
CABINET_JWT_SECRET=

# Домен для refresh-cookie. Если пусто — берётся хост из CABINET_PUBLIC_URL.
CABINET_COOKIE_DOMAIN=

# TTL токенов
CABINET_ACCESS_TTL_MINUTES=15
CABINET_REFRESH_TTL_DAYS=30

# База для synthetic customer.telegram_id у web-only клиентов 
# Должна быть ВЫШЕ любых реальных Telegram id, но умещаться в int64.
# Временный(мб вечный) костыль, чтобы не переделывать весь код бота под кабинет реализацию. 
CABINET_WEB_TELEGRAM_ID_BASE=7000000000000000000

# SMTP (для подтверждения email, сброса пароля; если пусто — email-функции отключены)
#БЕЗ НИХ НЕ БУДЕТ РАБОТАТЬ EMAIL регистрация/сброс пароля так-как туда приходит код пароль
CABINET_SMTP_HOST=smtp.beget.com
CABINET_SMTP_PORT=465
CABINET_SMTP_USER=noreply@domen.com
CABINET_SMTP_PASSWORD=
CABINET_SMTP_TLS=true
CABINET_MAIL_FROM="VPN <noreply@domen.com>"

# Google OAuth (опционально)
CABINET_GOOGLE_CLIENT_ID=
CABINET_GOOGLE_CLIENT_SECRET=
CABINET_GOOGLE_REDIRECT_URL=https://cabinet.domen.com/cabinet/api/auth/google/callback
# Yandex OAuth (опционально)
CABINET_YANDEX_CLIENT_ID=
CABINET_YANDEX_CLIENT_SECRET=
CABINET_YANDEX_REDIRECT_URL=https://cabinet.domen.com/cabinet/api/auth/yandex/callback
# VK OAuth (опционально)
CABINET_VK_CLIENT_ID=
CABINET_VK_CLIENT_SECRET=
CABINET_VK_CLIENT_REDIRECT_URL=https://cabinet.domen.com/cabinet/api/auth/vk/callback

# Telegram web auth mode:
# - oidc   : только Telegram OAuth 2.0 (рекомендуется)
# - widget : только Telegram Login Widget 1.0
CABINET_TELEGRAM_WEB_AUTH_MODE=widget
# Telegram Login Widget: username бота (без @), который будет логинить пользователей.
# Обязателен только для CABINET_TELEGRAM_WEB_AUTH_MODE=widget.
CABINET_TELEGRAM_LOGIN_BOT_USERNAME=
# Токен того же бота (из BotFather), что и username выше — для проверки HMAC виджета/miniapp.
# Если пусто — берётся TELEGRAM_TOKEN (тогда виджет должен быть от того же бота).
CABINET_TELEGRAM_LOGIN_BOT_TOKEN=
# Telegram OAuth 2.0 (OIDC) для web-логина/регистрации/привязки Telegram в кабинете.
# Mini App вход в Telegram-клиенте остаётся через source=miniapp + init_data.
# Redirect URL должен быть добавлен в BotFather/Telegram Login 2.0 и обычно равен:
# https://<ваш-домен-кабинета>/cabinet/api/auth/telegram/callback
CABINET_TELEGRAM_OIDC_CLIENT_ID=
CABINET_TELEGRAM_OIDC_CLIENT_SECRET=
# Если пусто и задан CABINET_TELEGRAM_OIDC_CLIENT_ID — по умолчанию собирается из CABINET_PUBLIC_URL:
# <CABINET_PUBLIC_URL>/cabinet/api/auth/telegram/callback
CABINET_TELEGRAM_OIDC_REDIRECT_URL=https://cabinet.domen.com/cabinet/api/auth/telegram/callback

# Cloudflare Turnstile (опционально, бесплатная альтернатива reCAPTCHA)
CABINET_TURNSTILE_ENABLED=false
CABINET_TURNSTILE_SITE_KEY=
CABINET_TURNSTILE_SECRET_KEY=

# Prometheus: GET /cabinet/api/metrics. Оба пусты — без Basic-auth (защищайте на reverse-proxy).
CABINET_METRICS_USER=
CABINET_METRICS_PASSWORD=



